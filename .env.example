# 複製成 .env 後填入你的金鑰。.env 已被 .gitignore 忽略，不會進版控。
# 程式啟動時會自動載入（common/env.py）。

# ===== L3 認知生成層（LLM）=====
# 供應商：stub（離線預設，免金鑰）| openai | ollama | gemini
LLM_PROVIDER=gemini
# 金鑰：gemini 可用 LLM_API_KEY 或 GEMINI_API_KEY / GOOGLE_API_KEY
GEMINI_API_KEY=your-gemini-api-key-here
# 可選：指定模型（Gemini 預設 gemini-2.0-flash；2.5-flash 是「思考」模型，需給足 LLM_MAX_TOKENS）
# LLM_MODEL=gemini-2.5-flash
# 可選：輸出 token 上限（2.5「思考」會先吃 token 再輸出，太小會截斷可見文字；預設 1024）
# LLM_MAX_TOKENS=1024

# --- 其他供應商範例 ---
# OpenAI：
#   LLM_PROVIDER=openai
#   LLM_API_KEY=sk-...
#   LLM_MODEL=gpt-4o-mini
# 本機 Ollama（免金鑰）：
#   LLM_PROVIDER=ollama
#   LLM_BASE_URL=http://localhost:11434/v1
#   LLM_MODEL=llama3.1

# ===== L2 MQTT（只有即時路徑需要；離線模擬不需要）=====
# MQTT_HOST=localhost
# MQTT_PORT=1883
