{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/plants/telemetry.schema.json",
  "title": "Plant Telemetry (L1 -> L2)",
  "description": "ESP32 邊緣感測層發布到 MQTT topic plants/{node_id}/telemetry 的封包。土壤/光照送 ADC 原始值，校準交由中介層 (L2)。",
  "type": "object",
  "required": ["node", "ts", "moisture_raw", "temp_c", "humidity_pct"],
  "additionalProperties": false,
  "properties": {
    "node": {
      "type": "string",
      "pattern": "^plant_[0-9]{2,}$",
      "description": "節點 ID，例如 plant_01"
    },
    "ts": {
      "type": "integer",
      "description": "Unix epoch 秒 (UTC)"
    },
    "moisture_raw": {
      "type": "integer",
      "minimum": 0,
      "maximum": 4095,
      "description": "土壤濕度 ADC 原始值 (GPIO34)"
    },
    "light_raw": {
      "type": "integer",
      "minimum": 0,
      "maximum": 4095,
      "description": "KY-018 光照 ADC 原始值 (GPIO35)"
    },
    "temp_c": {
      "type": "number",
      "description": "攝氏溫度 (BME280, I2C)"
    },
    "humidity_pct": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "相對濕度 % (BME280, I2C)"
    },
    "sim": {
      "type": "boolean",
      "description": "true 表示此封包含模擬資料（MVP 期間 BME280 未到貨，溫濕度為模擬）。正式實測時可省略或設為 false。"
    }
  },
  "examples": [
    {
      "node": "plant_01",
      "ts": 1730000000,
      "moisture_raw": 2850,
      "light_raw": 1980,
      "temp_c": 28.5,
      "humidity_pct": 61.2
    }
  ]
}
